---
import type { Tool } from '../lib/types';
import { getCategory } from '../lib/categories';
interface Props {
  tool: Tool;
}
const { tool } = Astro.props;
const cat = getCategory(tool.category);
---

<a
  href={`/rechner/${tool.slug}`}
  class="group flex h-full flex-col rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
>
  <div class="mb-2 flex items-center gap-2">
    {
      cat && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" class="text-brand-700" aria-hidden="true" focusable="false">
          <path d={cat.icon} stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      )
    }
    <span class="text-xs font-medium uppercase tracking-wide text-zinc-500">{cat?.name}</span>
  </div>
  <h3 class="text-base font-semibold text-zinc-900 group-hover:text-brand-700">{tool.title}</h3>
  <p class="mt-1 line-clamp-2 text-sm text-zinc-500">{tool.description}</p>
  <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-brand-700">
    Öffnen
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>
</a>
