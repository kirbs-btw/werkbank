---
import Logo from './Logo.astro';
import { CATEGORIES } from '../lib/categories';
import { NAV_MAIN } from '../config/site';
---

<header class="sticky top-0 z-40 border-b border-zinc-800 bg-zinc-900 text-zinc-100">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3">
    <a href="/" class="shrink-0" aria-label="Zur Startseite">
      <Logo variant="light" />
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Hauptnavigation">
      {
        CATEGORIES.map((c) => (
          <a
            href={`/kategorie/${c.slug}`}
            class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 transition hover:bg-zinc-800 hover:text-white"
          >
            {c.name}
          </a>
        ))
      }
      <a
        href="/ueber-uns"
        class="rounded-md px-3 py-2 text-sm font-medium text-zinc-300 transition hover:bg-zinc-800 hover:text-white"
      >
        Über uns
      </a>
      <a
        href="/rechner"
        class="ml-2 rounded-md bg-brand-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-brand-500"
      >
        Alle Rechner
      </a>
    </nav>

    <details class="relative md:hidden">
      <summary
        class="flex cursor-pointer list-none items-center rounded-md p-2 text-zinc-200 hover:bg-zinc-800"
        aria-label="Menü öffnen"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round"></path>
        </svg>
      </summary>
      <div class="absolute right-0 mt-2 w-56 rounded-lg border border-zinc-200 bg-white p-2 shadow-xl">
        {
          CATEGORIES.map((c) => (
            <a
              href={`/kategorie/${c.slug}`}
              class="block rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-100"
            >
              {c.name}
            </a>
          ))
        }
        <a href="/rechner" class="mt-1 block rounded-md bg-brand-600 px-3 py-2 text-sm font-semibold text-white transition hover:bg-brand-500">
          Alle Rechner
        </a>
        {
          NAV_MAIN.filter((n) => n.href === '/ueber-uns').map((n) => (
            <a href={n.href} class="block rounded-md px-3 py-2 text-sm text-zinc-700 hover:bg-zinc-100">
              {n.label}
            </a>
          ))
        }
      </div>
    </details>
  </div>
</header>
