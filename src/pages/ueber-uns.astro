---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
import { TOTAL_TOOLS } from '../lib/registry';
---

<BaseLayout
  title="Über uns"
  description={`Was ist ${SITE.name}? Kostenlose, präzise Online-Rechner und Generatoren für Maker und Handwerk.`}
  path="/ueber-uns"
>
  <div class="prose-werkbank mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight">Über {SITE.name}</h1>
    <p>
      {SITE.name} ist ein wachsender Werkzeugkasten mit aktuell {TOTAL_TOOLS} kostenlosen Online-Rechnern und
      Generatoren rund um 3D-Druck, CNC, Laser, Holz, Metall und Schrauben. Unser Ziel: die Zahlen, die in der
      Werkstatt ständig gebraucht werden, in Sekunden statt in PDF-Tabellen liefern.
    </p>
    <h2>Wofür wir stehen</h2>
    <ul>
      <li><strong>Präzise:</strong> nachvollziehbare Formeln, zu jedem Rechner dokumentiert.</li>
      <li><strong>Schnell:</strong> statische Seiten, Ergebnisse rechnen live im Browser.</li>
      <li><strong>Privat:</strong> keine Anmeldung, keine Datenübertragung deiner Eingaben.</li>
    </ul>
    <h2>Hinweis</h2>
    <p>
      Alle Ergebnisse sind sorgfältig erstellt, aber ohne Gewähr. Prüfe Werte vor sicherheits- oder
      kostenkritischer Verwendung gegen eine zweite Quelle.
    </p>
  </div>
</BaseLayout>
