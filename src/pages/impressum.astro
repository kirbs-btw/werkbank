---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';
---

<BaseLayout
  title="Impressum"
  description={`Impressum von ${SITE.name}.`}
  path="/impressum"
  noindex={true}
>
  <div class="prose-werkbank mx-auto max-w-3xl px-4 py-12">
    <h1 class="text-3xl font-extrabold tracking-tight">Impressum</h1>
    <p class="rounded-lg border border-amber-300 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      Platzhalter – vor dem Livegang mit echten Angaben nach § 5 DDG / § 18 MStV füllen.
    </p>
    <h2>Angaben gemäß § 5 DDG</h2>
    <p>
      [Name / Firma]<br />
      [Straße Hausnummer]<br />
      [PLZ Ort]
    </p>
    <h2>Kontakt</h2>
    <p>E-Mail: {SITE.email}</p>
    <h2>Verantwortlich für den Inhalt</h2>
    <p>[Name], Anschrift wie oben.</p>
  </div>
</BaseLayout>
