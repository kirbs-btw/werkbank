---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { TOOLS } from '../../lib/registry';
import { CATEGORIES } from '../../lib/categories';

const path = '/rechner';
const crumbs = [
  { name: 'Start', href: '/' },
  { name: 'Alle Rechner', href: path },
];
---

<BaseLayout
  title="Alle Rechner & Generatoren"
  description={`Übersicht aller ${TOOLS.length} kostenlosen Werkbank-Rechner für 3D-Druck, CNC, Laser, Holz, Metall und Schrauben.`}
  path={path}
>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumbs items={crumbs} />
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-zinc-900">Alle Rechner</h1>
    <p class="mt-2 text-zinc-600">{TOOLS.length} Tools – tippe zum Filtern.</p>

    <input
      id="tool-search"
      type="search"
      autocomplete="off"
      placeholder="Rechner suchen …"
      class="mt-6 w-full max-w-md rounded-lg border border-zinc-300 bg-white px-4 py-2.5 shadow-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-200"
    />

    <div id="tool-list" class="mt-8 space-y-10">
      {
        CATEGORIES.map((c) => {
          const list = TOOLS.filter((t) => t.category === c.slug);
          return list.length > 0 ? (
            <section data-cat-section>
              <h2 class="text-xl font-bold tracking-tight text-zinc-900">
                {c.name} <span class="text-sm font-normal text-zinc-500">({list.length})</span>
              </h2>
              <div class="mt-4 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
                {list.map((t) => (
                  <a
                    href={`/rechner/${t.slug}`}
                    data-tool
                    data-text={`${t.title} ${t.keywords.join(' ')}`.toLowerCase()}
                    class="block rounded-xl border border-zinc-200 bg-white px-4 py-3 text-sm shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
                  >
                    <span class="font-medium text-zinc-800">{t.title}</span>
                  </a>
                ))}
              </div>
            </section>
          ) : null;
        })
      }
    </div>
    <p id="no-results" class="mt-8 hidden text-zinc-500">Keine Rechner gefunden.</p>
  </div>

  <script>
    const q = document.getElementById('tool-search') as HTMLInputElement | null;
    const items = Array.from(document.querySelectorAll<HTMLElement>('[data-tool]'));
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-cat-section]'));
    const none = document.getElementById('no-results');

    function apply(term: string) {
      const t = term.trim().toLowerCase();
      let visible = 0;
      for (const el of items) {
        const match = !t || (el.dataset.text ?? '').includes(t);
        el.style.display = match ? '' : 'none';
        if (match) visible++;
      }
      for (const s of sections) {
        const any = Array.from(s.querySelectorAll<HTMLElement>('[data-tool]')).some(
          (e) => e.style.display !== 'none',
        );
        s.style.display = any ? '' : 'none';
      }
      none?.classList.toggle('hidden', visible > 0);
    }

    if (q) {
      q.addEventListener('input', () => apply(q.value));
      const initial = new URLSearchParams(location.search).get('q');
      if (initial) {
        q.value = initial;
        apply(initial);
      }
    }
  </script>
</BaseLayout>
