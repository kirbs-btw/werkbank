---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ToolCard from '../../components/ToolCard.astro';
import { CATEGORIES } from '../../lib/categories';
import { toolsByCategory } from '../../lib/registry';
import { GENERATORS } from '../../lib/generators';
import { breadcrumbLd } from '../../lib/schema';

export function getStaticPaths() {
  return CATEGORIES.map((c) => ({ params: { category: c.slug }, props: { category: c } }));
}

const { category } = Astro.props;
const tools = toolsByCategory(category.slug);
const generators = category.slug === 'generatoren' ? GENERATORS : [];
const hasContent = tools.length > 0 || generators.length > 0;
// Generatoren sind keine "Rechner" – Titel/H1 entsprechend ohne Suffix.
const heading = category.slug === 'generatoren' ? category.name : `${category.name}-Rechner`;
const path = `/kategorie/${category.slug}`;
const crumbs = [
  { name: 'Start', href: '/' },
  { name: category.name, href: path },
];
---

<BaseLayout
  title={heading}
  description={category.description}
  path={path}
  jsonLd={breadcrumbLd(crumbs.map((c) => ({ name: c.name, path: c.href })))}
>
  <div class="mx-auto max-w-6xl px-4 py-8">
    <Breadcrumbs items={crumbs} />
    <header class="mt-4 max-w-2xl">
      <h1 class="text-3xl font-extrabold tracking-tight text-zinc-900">{heading}</h1>
      <p class="mt-2 text-lg text-zinc-600">{category.description}</p>
    </header>

    {
      tools.length > 0 && (
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {tools.map((t) => (
            <ToolCard tool={t} />
          ))}
        </div>
      )
    }

    {
      generators.length > 0 && (
        <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {generators.map((g) => (
            <a
              href={`/generatoren/${g.slug}`}
              class="group flex h-full flex-col rounded-xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-brand-300 hover:shadow-md"
            >
              <span class="text-xs font-medium uppercase tracking-wide text-zinc-500">Generator</span>
              <h3 class="mt-1 text-base font-semibold text-zinc-900 group-hover:text-brand-700">{g.title}</h3>
              <p class="mt-1 text-sm text-zinc-500">{g.description}</p>
              <span class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-brand-700">
                Öffnen
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                  <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
            </a>
          ))}
        </div>
      )
    }

    {
      !hasContent && (
        <p class="mt-8 rounded-lg border border-dashed border-zinc-300 p-8 text-center text-zinc-500">
          Hier entstehen gerade neue Rechner – schau bald wieder vorbei.
        </p>
      )
    }
  </div>
</BaseLayout>
