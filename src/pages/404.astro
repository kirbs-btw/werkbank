---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Seite nicht gefunden"
  description="Diese Seite existiert nicht."
  path="/404"
  noindex={true}
>
  <div class="mx-auto max-w-3xl px-4 py-24 text-center">
    <p class="text-6xl font-extrabold text-brand-700">404</p>
    <h1 class="mt-4 text-3xl font-extrabold tracking-tight text-zinc-900">Diesen Rechner gibt es (noch) nicht</h1>
    <p class="mt-2 text-zinc-600">Die Seite wurde verschoben oder existiert nicht.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-brand-500">Zur Startseite</a>
      <a href="/rechner" class="rounded-lg border border-zinc-300 px-4 py-2 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-100">Alle Rechner</a>
    </div>
  </div>
</BaseLayout>
